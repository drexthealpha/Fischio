# fischio environment reference. Copy the values you need into a real, gitignored file:
#   - service vars go in your shell or a process manager
#   - front-end vars go in app/.env.local (Vite only exposes VITE_-prefixed vars)
# Never commit a filled-in copy. This file holds placeholders only.

# ---- Solana RPC ----
# Services that scan the chain (api, indexer, rewards) need an RPC that allows getProgramAccounts.
# Public devnet works but rate limits under load. Helius devnet allows getProgramAccounts (verified)
# and is what this project uses. Put the real value in the gitignored root .env, not here:
#   RPC=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
# Alchemy's free tier blocks getProgramAccounts and WebSocket confirmations, so use it front-end only.
RPC=https://api.devnet.solana.com

# Front end (put this in app/.env.local, with your own key). The app reads market lists from the
# API, so this does not strictly need getProgramAccounts.
#   VITE_RPC=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
VITE_RPC=
VITE_API=http://127.0.0.1:8790
VITE_INGEST=http://127.0.0.1:8795

# ---- TxLINE (server-side only, used by the ingestion service) ----
# Provision a free World Cup tier at https://txline.txodds.com/documentation/worldcup
TXLINE_JWT=
TXLINE_API_TOKEN=
# Where the keeper, seeders, and winner simulator read the live line from the ingestion service.
INGEST=http://127.0.0.1:8795

# ---- service ports (defaults shown; override if a port is taken) ----
# ingest 8795  api 8790  relayer 8791  indexer 8792  sponsor 8793  rewards 8794

# ---- keys (paths to gitignored keypair files; never inline a secret key) ----
# The relayer, sponsor, and keeper default to day1/devnet-wallet.json on devnet.
# SPONSOR_KEY=services/sponsor/sponsor-key.json
# KEEPER_KEY=day1/devnet-wallet.json

# ---- liquidity rewards (a labeled default, not a committed emission) ----
# REWARD_POOL_PER_DAY=1000
