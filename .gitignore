node_modules/
target/
.anchor/
test-ledger*/
dist/

# day1/ is dev scratch: secrets, TxLINE-owned data, and one-off probe scripts. Keep it local.
day1/

# secrets: keypairs and API credentials never enter the public repo
day1/devnet-wallet.json
day1/credentials.json
day1/actors-*.json
# defensive: any Solana keypair or service key file, anywhere, is a secret
**/*-keypair.json
**/*-key.json
**/keeper-key.json
**/*.secret
**/credentials.json

# local run artifacts
live.log
live-full.log.bak
day1/*.html
day1/history-*.json
test-results.txt
txline-app-screenshot.png

# TxLINE Data is licensed and must not be redistributed in a public repo (their terms 7.1).
# Keep the captured proofs, score snapshots, daily-roots dumps, and their program binary
# local only; each user fetches their own under their own TxLINE access (day1/ scripts do it).
test-fixtures/
day1/final-proofs.json
day1/proof-*.json
day1/*snapshot*.json
day1/scores-*.json
# their API spec, scraped docs, and reference integration code (keep local, do not publish)
day1/openapi.yaml
day1/worldcup.txt
day1/worldcup-code.txt
day1/subscription-tiers.txt
day1/onchain-validation-code.txt

# internal docs kept out of the public repo (README.md + docs/SECURITY.md are the public set)
docs/VIDEO-SCRIPT.md
MATCHDAY.md
CLAUDE.md
DESIGN-DRAFT.md
RECON.md
app/DESIGN.md
keeper-upload/
keeper-upload.zip
.claude/
services/relayer/relayer-key.json
services/sponsor/sponsor-key.json
services/indexer/index.db
services/rewards/rewards.db

# env files with real values, never commit (.env.example is the committed placeholder)
.env
.env.local
.env.*.local
app/.env.local
!.env.example
