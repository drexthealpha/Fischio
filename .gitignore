node_modules/

# Rust build output, except the IDLs.
#
# The bots and the CLI read target/idl/*.json to talk to the deployed programs. Those files are not
# build waste, they are the public interface of the programs: anyone can fetch the same thing from
# the chain, and the app already ships its own copies under app/src. Ignoring them meant a fresh
# clone could not run a single bot without a full Rust toolchain and an anchor build, which is how
# the deployed box ended up crash-looping on ENOENT for fischio_market.json.
#
# The four-line shape is deliberate. Ignoring `target/` outright excludes the directory itself, and
# git will not look inside an excluded directory, so a later negation can never match. Excluding the
# contents instead leaves the directory visible for the negations below to work against.
target/*
!target/idl/
target/idl/*
!target/idl/*.json

.anchor/
test-ledger*/
dist/

# local/ is dev scratch: secrets, TxLINE-owned data, and one-off probe scripts. Keep it local.
local/

# secrets: keypairs and API credentials never enter the public repo
local/devnet-wallet.json
local/credentials.json
local/actors-*.json
# defensive: any Solana keypair or service key file, anywhere, is a secret
**/*-keypair.json
**/*-key.json
**/keeper-key.json
**/*.secret
**/credentials.json

# local run artifacts
live.log
live-full.log.bak
local/*.html
local/history-*.json
test-results.txt
txline-app-screenshot.png

# TxLINE Data is licensed and must not be redistributed in a public repo (their terms 7.1).
# Keep the captured proofs, score snapshots, daily-roots dumps, and their program binary
# local only; each user fetches their own under their own TxLINE access (local/ scripts do it).
test-fixtures/
local/final-proofs.json
local/proof-*.json
local/*snapshot*.json
local/scores-*.json
# their API spec, scraped docs, and reference integration code (keep local, do not publish)
local/openapi.yaml
local/worldcup.txt
local/worldcup-code.txt
local/subscription-tiers.txt
local/onchain-validation-code.txt

# internal docs kept out of the public repo (README.md + docs/SECURITY.md are the public set)
docs/VIDEO-SCRIPT.md
MATCHDAY.md
CLAUDE.md
DESIGN-DRAFT.md
RECON.md
app/DESIGN.md
keeper-upload/
keeper-upload.zip
.claude/
# scratch tooling and TxLINE's converted OpenAPI spec. _spec.json is local/openapi.yaml as JSON,
# which is their licensed data (terms 7.1) and must never be committed; the _*.mjs are one-off
# probe scripts. Underscore-prefixed root files are dev scratch by convention.
/_*.mjs
/_*.json

services/relayer/relayer-key.json
services/sponsor/sponsor-key.json
services/indexer/index.db
services/rewards/rewards.db

# env files with real values, never commit (.env.example is the committed placeholder)
.env
.env.local
.env.*.local
app/.env.local
!.env.example
